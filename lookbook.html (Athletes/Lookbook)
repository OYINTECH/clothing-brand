<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ELARA | Athletes</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <header class="header">
    <div class="logo"><a href="index.html">ELARA</a></div>

    <nav class="nav">
      <a href="shop.html">Shop</a>
      <a href="shop.html">Women</a>
      <a href="shop.html">Gym Sets</a>
      <a href="lookbook.html">Athletes</a>
      <a href="about.html">About</a>
      <a href="contact.html">Contact</a>
    </nav>

    <button class="cartBtn" id="cartBtn">Bag (<span id="cartCount">0</span>)</button>
  </header>

  <section class="section">
    <h2>Athletes</h2>
    <p style="color:var(--muted); max-width:720px;">
      ELARA in motion — strength days, cardio fits, and gym sets built for performance.
    </p>

    <div class="lookbook" style="margin-top:18px;">
      <div class="lbCard">Training Set</div>
      <div class="lbCard">Strength Day</div>
      <div class="lbCard">Cardio Fit</div>
    </div>
  </section>

  <footer class="footer">
